    {
      "parameters": {
        "jsCode": "// 1. Captura o payload vindo do nó HTTP Request\nconst payload = $input.first().json;\n\n// 2. Validação defensiva dos campos obrigatórios na raiz e sub-objetos\nconst hasName = payload?.name !== undefined && payload?.name !== null;\nconst hasTemp = payload?.main?.temp !== undefined && payload?.main?.temp !== null;\n\n// 3. Validação do array weather e suas propriedades internas (Index 0)\nconst hasWeatherArray = Array.isArray(payload?.weather) && payload?.weather?.length > 0;\nconst firstWeatherItem = hasWeatherArray ? payload.weather[0] : null;\n\nconst hasWeatherMain = firstWeatherItem?.main !== undefined && firstWeatherItem?.main !== null && firstWeatherItem?.main !== \"\";\nconst hasWeatherDesc = firstWeatherItem?.description !== undefined && firstWeatherItem?.description !== null && firstWeatherItem?.description !== \"\";\n\n// 4. O contrato só é válido se os 4 pilares essenciais existirem e estiverem preenchidos\nconst isContractValid = hasName && hasTemp && hasWeatherArray && hasWeatherMain && hasWeatherDesc;\n\n// 5. Retorna a flag para a árvore de decisão, preservando o payload original\nreturn [{\n  json: {\n    ...payload,\n    is_valid_payload: isContractValid\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
