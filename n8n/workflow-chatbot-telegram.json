    {
      "parameters": {
        "jsCode": "// 1. Captura o texto bruto do Telegram\nlet input = $input.first().json.message.text || \"\";\n\n// 2. Transforma em minúsculas e remove acentos\ninput = input.toLowerCase().normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\");\n\n// 3. Regex estrita: captura [letras/espaços da cidade], obriga a ter uma vírgula, e captura [2 letras da UF]\nconst regex = /^([a-z\\s]+),\\s*([a-z]{2})(?:\\s*,?\\s*br)?$/;\nconst match = input.trim().match(regex);\n\nlet queueValue = \"\";\n\nif (match) {\n  const cidade = match[1].trim();\n  const uf = match[2].trim();\n  queueValue = `${cidade},${uf},br`;\n}\n\n// 4. Retorna objeto com a variável \"queue\"\nreturn {\n  queue: queueValue\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
